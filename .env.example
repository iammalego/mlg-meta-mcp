# Required: Meta System User token used by the MCP server
META_SYSTEM_USER_TOKEN=your_system_user_token_here

# Optional: Meta Graph API version
META_API_VERSION=v22.0

# Optional: Logger verbosity (debug, info, warn, error)
LOG_LEVEL=info

# Optional: In-memory ad account discovery cache TTL in seconds
CACHE_TTL_SECONDS=300

# Optional: Retry count for retryable Meta API failures
MAX_RETRIES=3

# Optional: Base retry delay in milliseconds for exponential backoff
RETRY_BASE_DELAY_MS=1000
